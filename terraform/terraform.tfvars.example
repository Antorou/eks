# ============================================================
# FIRST-TIME SETUP
# ============================================================
# 1. Create the S3 + DynamoDB backend (once):
#      ./bootstrap.sh
#
# 2. Initialise Terraform with the generated backend config:
#      terraform init -backend-config=backend.hcf
#
# 3. Copy this file and apply:
#      cp terraform.tfvars.example terraform.tfvars
#      terraform apply
#
# Notes:
#   - terraform.tfvars is gitignored
#   - db_password is auto-generated — retrieve after apply:
#       terraform output -raw rds_password
# ============================================================

aws_region   = "eu-west-3"
project_name = "obs-lab"
environment  = "dev"

vpc_cidr            = "10.0.0.0/16"
availability_zones  = ["eu-west-3a", "eu-west-3b"]
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]

kubernetes_version = "1.30"
node_instance_type = "t3.medium"
node_desired_size  = 1

db_name           = "recipes"
db_username       = "appuser"
db_instance_class = "db.t3.micro"
