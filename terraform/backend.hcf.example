# This file is generated by bootstrap.sh — do not write it by hand.
# bootstrap.sh will create backend.hcf with your actual account ID baked in.
#
# The real backend.hcf is gitignored (it's environment-specific, not secret).

bucket         = "obs-lab-tfstate-<your-aws-account-id>"
key            = "dev/terraform.tfstate"
region         = "eu-west-3"
dynamodb_table = "obs-lab-tfstate-lock"
encrypt        = true
